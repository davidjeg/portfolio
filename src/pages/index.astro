---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import About from "../components/About.astro";
import Contact from "../components/Contact.astro";
import Skills from "../components/Skills.astro";
import ThreeCanvas from "../components/ThreeCanvas.astro";
import HeroText from "../components/HeroText.astro";
import Container from "../components/Container.astro";
import Footer from "../components/Footer.astro";

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout>
  <Navbar />
  <Container
    id="home"
    class="lg:mt-32 md:mt-24 xs:md-20 flex md:flex-row flex-col gap-4 overflow-hidden h-140"
  >
    <HeroText />
    <ThreeCanvas />
  </Container>
  <div class="min-h-screen relative overflow-hidden">
    <div id="canvas" class="absolute inset-0 -z-10"></div>
    <div class="bg-zinc-950/70 backdrop-blur-3xl relative z-10">
      <About />
      <Skills />
      <Contact />
      <Footer />
    </div>
  </div>
</Layout>

<script>
  import vertexShader from "../shaders/vertexShader.glsl?raw";
  import fragmentShader from "../shaders/fragmentShader.glsl?raw";
  import * as THREE from "three";
  import { UnrealBloomPass } from "three/addons/postprocessing/UnrealBloomPass.js";
  import { EffectComposer } from "three/examples/jsm/postprocessing/EffectComposer.js";
  import { RenderPass } from "three/examples/jsm/postprocessing/RenderPass.js";
  const canvas = document.querySelector<HTMLDivElement>("#canvas");
  const renderer = new THREE.WebGLRenderer({ antialias: true });
  if (canvas) {
    const canvasW = canvas.clientWidth;
    const canvasH = canvas.clientHeight;
    const camera = new THREE.PerspectiveCamera(
      75,
      canvasW / canvasH,
      0.1,
      1000,
    );
    camera.position.set(0, 0, 20);
    const scene = new THREE.Scene();
    scene.background = new THREE.Color(0x09090b);
    renderer.setSize(canvasW, canvasH);

    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    canvas.appendChild(renderer.domElement);
    const bloomPass = new UnrealBloomPass(
      new THREE.Vector2(window.innerWidth, window.innerHeight),
      0.1,
      0.01,
      0.2,
    );
    const composer = new EffectComposer(renderer);
    composer.addPass(new RenderPass(scene, camera));
    composer.addPass(bloomPass);
    composer.setSize(canvas.clientWidth, canvas.clientHeight);
    scene.add(camera);
    renderer.render(scene, camera);

    const material = new THREE.ShaderMaterial({
      uniforms: {
        uTime: { value: 0 },
        uColor: { value: new THREE.Color("#EC4899") },
      },
      vertexShader: vertexShader,
      fragmentShader: fragmentShader,
    });

    const light = new THREE.AmbientLight(0xffffff, 1);
    scene.add(light);

    const clock = new THREE.Timer();
    let elapsed = 0;

    // bounds pantalla
    function getBounds(camera: THREE.PerspectiveCamera, distance: number) {
      const vFov = (camera.fov * Math.PI) / 180;
      const height = 2 * Math.tan(vFov / 2) * distance;
      const width = height * camera.aspect;

      return {
        x: width / 2,
        y: height / 2,
      };
    }

    const distance = 10;
    let bounds = getBounds(camera, distance);

    const SPEED = 0.03;

    const sphereData: {
      mesh: THREE.Mesh;
      vel: THREE.Vector3;
    }[] = [];

    const maxInScreen = 3;

    for (let i = 0; i < maxInScreen; i++) {
      const geometry = new THREE.SphereGeometry(2, 32, 32);
      const mesh = new THREE.Mesh(geometry, material);

      mesh.position.set(
        (Math.random() - 0.5) * 20,
        (Math.random() - 0.5) * 20,
        Math.random() * 10,
      );

      const angle = Math.random() * Math.PI * 2;

      const vel = new THREE.Vector3(
        Math.cos(angle) * SPEED,
        Math.sin(angle) * SPEED,
        0,
      );

      sphereData.push({ mesh, vel });
      scene.add(mesh);
    }

    function animate() {
      requestAnimationFrame(animate);

      clock.update();
      const delta = clock.getDelta();

      material.uniforms.uTime.value += delta;

      sphereData.forEach((obj) => {
        const { mesh, vel } = obj;

        mesh.position.x += vel.x * delta * 60;
        mesh.position.y += vel.y * delta * 60;

        // rebote X
        if (mesh.position.x > bounds.x || mesh.position.x < -bounds.x) {
          vel.x *= -1;
          mesh.position.x = THREE.MathUtils.clamp(
            mesh.position.x,
            -bounds.x,
            bounds.x,
          );
        }

        // rebote Y
        if (mesh.position.y > bounds.y || mesh.position.y < -bounds.y) {
          vel.y *= -1;
          mesh.position.y = THREE.MathUtils.clamp(
            mesh.position.y,
            -bounds.y,
            bounds.y,
          );
        }
      });

      composer.render();
    }
    function onResize() {
      camera.aspect = canvasW / canvasH;
      camera.updateProjectionMatrix();

      renderer.setSize(canvasW, canvasH);
      composer.setSize(canvasW, canvasH);

      bloomPass.setSize(canvasW, canvasH);
      bounds = getBounds(camera, distance);
    }

    window.addEventListener("resize", onResize);

    animate();
  }
</script>

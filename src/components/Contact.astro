---
import Container from "./Container.astro";
interface ContactFormField {
  label: string;
  name: string;
  type: "text" | "email";
  placeholder?: string;
}
const contactInputs: ContactFormField[] = [
  { label: "Name", name: "name", type: "text", placeholder: "Your name" },
  { label: "Email", name: "email", type: "email", placeholder: "Your email" },
];
---

<Container>
  <div class="py-16 md:py-24">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {/* LEFT */}
      <div class="flex flex-col justify-center">
        <div>
          <p class="text-4xl font-bold mb-6">Get In Touch</p>
          <div class="flex items-center gap-4 mb-4">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="size-6"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M10.5 1.5H8.25A2.25 2.25 0 0 0 6 3.75v16.5a2.25 2.25 0 0 0 2.25 2.25h7.5A2.25 2.25 0 0 0 18 20.25V3.75a2.25 2.25 0 0 0-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3"
              ></path>
            </svg>
            <span>+593 980583480</span>
          </div>

          {/*EMAIL */}
          <div class="flex items-center gap-4">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="size-6"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"
              ></path>
            </svg>
            <a
              class="underline"
              href="mailto:davideg96@outlook.com?subject=Porfolio Contact"
              >contact@david-encarnacion.com</a
            >
          </div>
        </div>
      </div>
      <form
        id="contact-form"
        class="flex flex-col gap-6 bg-zinc-900/50 p-6 rounded-lg"
      >
        {
          contactInputs.map(({ label, name, type, placeholder }) => (
            <label class="flex flex-col gap-2">
              {label}
              <input
                required
                name={name}
                placeholder={placeholder}
                type={type}
                class="p-4 outline-none 
        border-2 bg-zinc-950 border-zinc-400 rounded-md hover:border-zinc-700/50 focus:border-zinc-500 transition"
              />
            </label>
          ))
        }
        <label class="flex flex-col gap-2">
          Message
          <textarea
            minlength="10"
            required
            class="resize-none outline-none rounded-md p-4 border-2 h-28 border-zinc-400
        hover:border-zinc-700 focus:border-zinc-500 transition bg-zinc-950"
            placeholder="Message..."
            name="message"></textarea>
        </label>
        <button
          type="submit"
          class="p-2 rounded-md bg-blue-500 hover:bg-blue-600 active:bg-blue-700 transition"
          >Send message</button
        >
      </form>
    </div>
  </div>
  <div
    id="modal_message"
    class="fixed inset-0 transition duration-200 opacity-0 pointer-events-none"
  >
    <div
      class="w-full max-w-lg bg-zinc-900 p-6 rounded-lg flex flex-col jutify-center items-center gap-4
      absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2"
    >
      <img src="./icons/check.png" class="h-20" />
      <p>Thanks! Your message has been sent.</p>
    </div>
  </div>
</Container>

<script>
  const form = document.querySelector<HTMLFormElement>("#contact-form");
  const modal = document.querySelector<HTMLDivElement>("#modal_message");

  form?.addEventListener("submit", async (e: SubmitEvent) => {
    e.preventDefault();
    const data = new FormData(form);
    const res = await fetch("https://formspree.io/f/xkoabjnw", {
      method: "POST",
      body: data,
      headers: {
        Accept: "application/json",
      },
    });
    if (res.ok) {
      console.log("enviado");
      modal?.classList.add("opacity-100");
      form.reset();
      setTimeout(() => {
        modal?.classList.remove("opacity-100");
        modal?.classList.add("opacity-0");
      }, 600);
    }
  });
</script>
